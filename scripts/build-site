#!/usr/bin/env bash
# shellcheck shell=bash
#
# scripts/build-site

set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

source "$ROOT_DIR/scripts/lib/lib.sh"
source "$ROOT_DIR/scripts/lib/paths.sh"

derive_binary_paths

usage() {
  cat >&2 <<EOF
Usage:
  scripts/build-site [--] [site build args...]

Builds the static site output directory:
  out: $ROOT_DIR/build/public

Notes:
  - Build behavior such as --clean/--no-clean is handled by the site build command.
  - Pass extra args after '--' to forward to 'site build'.
EOF
}

main() {
  case "${1:-}" in
  -h | --help | help)
    usage
    exit 0
    ;;
  esac

  need_cmd go
  need_cmd templ

  if [[ "${1:-}" == "--" ]]; then
    shift
  fi

  local out_dir="$ROOT_DIR/build/public"

  # Guardrails
  require_dir "$ROOT_DIR/content" "Refusing: content dir not found"
  require_dir "$ROOT_DIR/templates" "Refusing: templates dir not found"
  require_dir "$ROOT_DIR/static" "Refusing: static dir not found"

  info "Running templ generate..."
  templ generate

  if [[ -n "${BIN_PATH:-}" && -x "$BIN_PATH" ]]; then
    info "Building site with compiled tool: $BIN_PATH"
    "$BIN_PATH" build \
      --out "$out_dir" \
      --static "$ROOT_DIR/static" \
      --assets "assets" \
      "$@"
  else
    info "Building site with go run..."
    go run "$CMD_DIR" build \
      --out "$out_dir" \
      --static "$ROOT_DIR/static" \
      --assets "assets" \
      "$@"
  fi

  ok "... site output written to $out_dir."
}

main "$@"
